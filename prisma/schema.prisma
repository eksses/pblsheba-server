generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String     @id @default(cuid())
  name                 String
  fatherName           String
  dob                  DateTime
  nid                  String?    @unique
  phone                String     @unique
  email                String?
  address              String?
  paymentNumber        String?
  imageUrl             String?
  password             String
  role                 Role       @default(member)
  status               Status     @default(pending)
  referredById         String?
  paymentMethod        String?
  paymentTrxId         String?
  paymentVerified      Boolean    @default(false)
  verifiedBy           VerifiedBy @default(none)
  nidVerified          Boolean    @default(false)
  editRequestPending   Boolean    @default(false)
  editRequestedChanges Json?
  editApproved         Boolean    @default(false)
  firstLogin           Boolean    @default(true)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  surveys              Survey[]
  referredBy           User?      @relation("Referral", fields: [referredById], references: [id])
  referrals            User[]             @relation("Referral")
  pushSubscriptions    PushSubscription[]
}

model Survey {
  id            String   @id @default(cuid())
  name          String
  fathersName   String
  wardNo        String
  farmAnimals   String?
  farmableLand  String?
  houseType     String?
  familyMembers Int?
  gender        String?
  childrenBoy   Int?
  childrenGirl  Int?
  monthlyIncome Float?
  phone         String   @unique
  submittedById String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  submittedBy   User     @relation(fields: [submittedById], references: [id])
}

model Setting {
  id                     Int      @id @default(1)
  registrationFee        Int      @default(365)
  jobApplicationsEnabled Boolean  @default(true)
  employeeCanViewAll     Boolean  @default(false)
  smsWebhookKey          String?  @default("pblsheba_secret_key")
  paymentMethods         Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model JobApplication {
  id                 String   @id @default(cuid())
  postAppliedFor     String
  officeNameCode     String?
  date               DateTime @default(now())
  roleCode           String
  nameBn             String
  nameEn             String
  fatherName         String
  motherName         String
  presentAddress     String
  permanentAddress   String
  dob                String
  age                Int?
  religion           String?
  nid                String
  nationality        String   @default("Bangladeshi")
  profession         String?
  maritalStatus      String?
  spouseName         String?
  mobile             String
  email              String?
  mobileBankingType  String?
  mobileBankingNumber String?
  education          Json?
  nomineeName        String
  nomineeAddress     String?
  nomineeRelationship String?
  nomineeMobile      String?
  photoUrl           String?
  signatureUrl       String?
  status             String   @default("pending")
  statusNote         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  userId    String?
  action    String?
  ip        String?
  createdAt DateTime @default(now())
}

enum Role {
  member
  employee
  owner
}

enum Status {
  pending
  approved
  rejected
}

enum VerifiedBy {
  admin
  system
  none
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
